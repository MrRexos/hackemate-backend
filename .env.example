PORT=3000

# Secrets → .env.local (vegeu .env.local.example)

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Font de dades logística ---
# joined = dues taules (per defecte; vegeu supabase-logistics-schema.sql)
# flat = una vista/taula amb una fila per producte (defineix LOGISTICS_FLAT_VIEW)
LOGISTICS_SOURCE_MODE=joined

LOGISTICS_FLAT_VIEW=logistics_entregues_pedidos_pla
LOGISTICS_TABLE_ENTREGUES=logistics_entregues
LOGISTICS_TABLE_PEDIDOS=logistics_pedidos
LOGISTICS_ENTREGUES_TABLE=logistics_entregues

# Magatzem per al sweep (lon, lat)
LOGISTICS_MAGATZEM_LON=2.1718
LOGISTICS_MAGATZEM_LAT=41.5278

# Script npm run planificacio:informe (opcional)
# PLANIFICACIO_OSRM=false
# PLANIFICACIO_ASSIGNACIO_COMPLETA=true

# Opcional: columnes si els noms del company difereixen (vegeu database/INTEGRACIO-SUPABASE.md)
# LOGISTICS_COL_ENTREGA_ID=entrega_id
# LOGISTICS_ENTREGA_PK=id
# LOGISTICS_PEDIDO_ENTREGA_ID=entrega_id
