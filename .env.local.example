# Copia a `.env.local` (mateixa carpeta que package.json)

SUPABASE_URL=https://iadbbqhpufyadxnvawng.supabase.co
SUPABASE_PUBLISHABLE_KEY=

# Opcional:
# SUPABASE_SERVICE_ROLE_KEY=

# joined (per defecte al codi) = logistics_entregues + logistics_pedidos
# flat = vista pla (LOGISTICS_FLAT_VIEW)
LOGISTICS_SOURCE_MODE=joined

LOGISTICS_FLAT_VIEW=logistics_entregues_pedidos_pla

# Mode joined: només cal si els noms del company difereixen dels defaults
# LOGISTICS_TABLE_ENTREGUES=logistics_entregues
# LOGISTICS_TABLE_PEDIDOS=logistics_pedidos

# Taula per UPDATE de coords (normalment = taula mestra d’entregues)
LOGISTICS_ENTREGUES_TABLE=logistics_entregues
