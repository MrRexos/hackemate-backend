{
  "name": "hackemate-backend",
  "version": "1.0.0",
  "description": "Backend API para Hackemate",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "prova:sweep": "node src/scripts/prova-sweep.js",
    "prova:bars40": "node src/scripts/prova-bars-bcn-40.js",
    "fixtures:excel": "node src/scripts/genera-fixture-excel-prova.js",
    "prova:excel": "node src/main-rutes-excel.js fixtures/excel/comandes-prova.xlsx --mock-geocode",
    "rutes:excel": "node src/main-rutes-excel.js",
    "joc-proves:rutes": "node src/scripts/joc-proves-rutes-mollet.js",
    "joc-proves:rutes:fast": "node src/scripts/joc-proves-rutes-mollet.js --fast",
    "joc-proves:rutes:excel": "node src/scripts/joc-proves-rutes-mollet.js --excel fixtures/excel/comandes-prova.xlsx --mock-geocode --fast"
  },
  "keywords": [
    "hackemate",
    "express",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "xlsx": "^0.18.5"
  }
}
